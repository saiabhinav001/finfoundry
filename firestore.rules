rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ══════════════════════════════════════════════════════════
    // All data is read/written through Next.js API routes using
    // the Firebase Admin SDK, which bypasses these rules entirely.
    // Therefore, deny ALL client-side access for maximum security.
    // ══════════════════════════════════════════════════════════

    // Users can read their own profile (needed by auth context)
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }

    // Deny everything else — Admin SDK handles all reads/writes
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
