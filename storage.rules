rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Helper: check if user has admin or editor role via custom claims
    function isPrivileged() {
      return request.auth != null
          && request.auth.token.role in ['admin', 'editor'];
    }

    // ── Event images ────────────────────────────────────────
    match /events/{allPaths=**} {
      allow read: if true;
      allow write: if isPrivileged();
    }

    // ── Team member photos ──────────────────────────────────
    match /team/{allPaths=**} {
      allow read: if true;
      allow write: if isPrivileged();
    }

    // ── Resource files ──────────────────────────────────────
    match /resources/{allPaths=**} {
      allow read: if true;
      allow write: if isPrivileged();
    }

    // ── Deny everything else ────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
